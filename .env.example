# GRX10 Automated Market Research Tool — environment template.
# Copy to `.env` for local dev. On Render these are set via the dashboard /
# the `grx10-shared` env-var group (see render.yaml). NEVER commit a real .env.

# ----------------------------------------------------------------------------
# Database (Render Postgres in prod; local Postgres in dev)
# ----------------------------------------------------------------------------
# SQLAlchemy + psycopg3. A plain postgres:// URL is auto-upgraded to
# postgresql+psycopg:// by the app, so paste the Render connection string as-is.
DATABASE_URL=postgres://grx10:grx10@localhost:5432/grx10_market_research

# ----------------------------------------------------------------------------
# WorkOS managed auth (Q10) — SSO/SAML/OIDC + email/Google for pre-IdP work
# ----------------------------------------------------------------------------
# NOTE: real WorkOS secret keys look like sk_test_… / sk_live_… — paste yours here.
WORKOS_API_KEY=your-workos-api-key
WORKOS_CLIENT_ID=your-workos-client-id
# >= 32 chars — encrypts the AuthKit session cookie.
WORKOS_COOKIE_PASSWORD=change-me-to-a-long-random-string-min-32-chars
# Where WorkOS sends the user back after login (the frontend's /callback route).
WORKOS_REDIRECT_URI=http://localhost:3000/callback

# ----------------------------------------------------------------------------
# Credential security (Q9) — envelope encryption master key for pgcrypto
# ----------------------------------------------------------------------------
# Wraps the per-credential data keys. WARNING: rotating this invalidates every
# stored connector credential. Generate with: openssl rand -base64 32
CRED_MASTER_KEY=change-me-base64-32-bytes

# ----------------------------------------------------------------------------
# Anthropic (Q6 AI field-mapping for generic-REST connectors, Q8 web-search)
# ----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ----------------------------------------------------------------------------
# Pipeline failure notifications (Q7) — optional Slack incoming webhook
# ----------------------------------------------------------------------------
SLACK_WEBHOOK_URL=

# ----------------------------------------------------------------------------
# Frontend (Next.js) — public URLs
# ----------------------------------------------------------------------------
# Base URL of the FastAPI service that server components fetch from.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Public URL of the frontend itself (used by AuthKit redirects).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----------------------------------------------------------------------------
# Pipeline tuning (optional)
# ----------------------------------------------------------------------------
# Default ingestion lookback hint passed to connector.pull(since=...).
PIPELINE_SINCE=
LOG_LEVEL=INFO

# ----------------------------------------------------------------------------
# Connector API keys — DO NOT put these here in production.
# Connector secrets are entered write-only via the Connectors admin UI (Q9) and
# stored encrypted in `connector_credentials`. The values below are only for
# convenience when probing a single connector locally during development.
# ----------------------------------------------------------------------------
# COMTRADE_API_KEY=
# CENSUS_API_KEY=
# EDINET_API_KEY=
# FRED_API_KEY=
